{
  "name": "loi-tran-blog",
  "version": "1.5.6",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "cross-env SOCKET=true node ./scripts/next-remote-watch.js ./data",
    "dev": "next dev",
    "dev2": "concurrently \"node scripts/watch-terms.js\" \"next dev\"",
    "build": "node scripts/build-terms.js && next build && node ./scripts/generate-sitemap.cjs",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "prepare": "husky install",
    "lint:fix": "eslint . --fix",
    "lint:strict": "eslint . --max-warnings=0",
    "build:terms": "node scripts/build-terms.js"
  },
  "dependencies": {
    "@fontsource/inter": "4.5.2",
    "@mailchimp/mailchimp_marketing": "^3.0.58",
    "@mdx-js/esbuild": "^2.3.0",
    "@mdx-js/react": "^3.1.1",
    "@tailwindcss/forms": "^0.4.0",
    "@tailwindcss/typography": "^0.5.0",
    "builtin-modules": "^5.1.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.19.12",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "framer-motion": "^12.38.0",
    "github-slugger": "^1.5.0",
    "gray-matter": "^4.0.2",
    "image-size": "1.0.0",
    "mdx-bundler": "^9.2.0",
    "next": "^15.5.15",
    "next-contentlayer2": "^0.5.8",
    "next-themes": "^0.4.6",
    "preact": "^10.6.2",
    "prismjs": "^1.30.0",
    "react": "^18.2.0",
    "react-ace": "^14.0.1",
    "react-copy-to-clipboard": "^5.1.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "reading-time": "1.3.0",
    "rehype-autolink-headings": "^6.1.0",
    "rehype-citation": "^0.4.0",
    "rehype-katex": "^6.0.2",
    "rehype-preset-minify": "6.0.0",
    "rehype-prism-plus": "^1.1.3",
    "rehype-slug": "^5.0.0",
    "remark": "^15.0.1",
    "remark-footnotes": "^4.0.1",
    "remark-gfm": "^3.0.1",
    "remark-math": "^5.1.1",
    "remark-parse": "^11.0.0",
    "sharp": "^0.32.6",
    "slugify": "^1.6.9",
    "unist-util-visit": "^4.1.2"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@eslint/js": "^9.39.4",
    "@next/bundle-analyzer": "12.1.4",
    "@next/eslint-plugin-next": "^16.2.4",
    "@svgr/webpack": "^6.5.1",
    "@tailwindcss/postcss": "^4.2.4",
    "autoprefixer": "10.4.5",
    "cross-env": "^7.0.3",
    "dedent": "^0.7.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.15",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "file-loader": "^6.0.0",
    "globals": "^17.6.0",
    "globby": "11.0.3",
    "husky": "^6.0.0",
    "inquirer": "^8.1.1",
    "lint-staged": "^11.0.0",
    "next-remote-watch": "^1.0.0",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "socket.io": "^4.4.0",
    "socket.io-client": "^4.4.0",
    "tailwindcss": "^4.2.4",
    "tsconfig-paths": "^4.2.0"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  }
}
