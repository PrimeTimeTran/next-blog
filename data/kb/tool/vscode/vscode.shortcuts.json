[
  // Focus
  {
    "key": "cmd+alt+1",
    "command": "terminal.focus"
  },
  {
    "key": "cmd+alt+2",
    "command": "workbench.debug.action.focusRepl"
  },
  {
    // Visibility & Sidebar
    "key": "cmd+alt+a",
    "command": "workbench.action.toggleActivityBarVisibility"
  },
  {
    "key": "cmd+alt+s",
    "command": "workbench.action.toggleStatusbarVisibility"
  },
  {
    "key": "cmd+alt+\\",
    "command": "workbench.files.action.collapseExplorerFolders"
  },
  {
    "key": "cmd+e",
    "command": "workbench.files.action.focusFilesExplorer"
  },
  {
    "key": "cmd+e",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "explorerViewletVisible && filesExplorerFocus"
  },
  {
    "key": "cmd+'",
    "command": "workbench.action.terminal.focus"
  },
  {
    "key": "cmd+'",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "terminalFocus"
  },
  {
    "key": "cmd+g",
    "command": "workbench.view.scm",
    "when": "gitlens:enabled && config.gitlens.keymap == 'chorded'"
  },
  {
    "key": "cmd+alt+z",
    "command": "workbench.view.extension.gitlens"
  },
  {
    "key": "ctrl+alt+down",
    "command": "workbench.action.nextSideBarView"
  },
  {
    "key": "ctrl+alt+up",
    "command": "workbench.action.previousSideBarView"
  },
  // Editor/TerminalSizing
  {
    "key": "cmd+alt+up",
    "command": "workbench.action.decreaseViewHeight"
  },
  {
    "key": "cmd+alt+down",
    "command": "workbench.action.increaseViewHeight"
  },
  {
    "key": "cmd+alt+right",
    "command": "workbench.action.decreaseViewWidth",
    "when": "editorFocus"
  },
  {
    "key": "cmd+alt+left",
    "command": "workbench.action.increaseViewWidth",
    "when": "editorFocus"
  },
  // Terminal Navigation
  {
    "key": "cmd+alt+right",
    "command": "workbench.action.terminal.focusNextPane",
    "when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
  },
  {
    "key": "cmd+alt+left",
    "command": "workbench.action.terminal.focusPreviousPane",
    "when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
  },
  {
    "key": "ctrl+alt+down",
    "command": "workbench.action.terminal.focusNext",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+alt+up",
    "command": "workbench.action.terminal.focusPrevious",
    "when": "terminalFocus"
  },
  {
    "key": "alt+ctrl+left",
    "command": "workbench.action.previousPanelView"
  },
  {
    "key": "alt+ctrl+right",
    "command": "workbench.action.nextPanelView"
  },
  {
    "key": "cmd+backspace",
    "command": "workbench.action.terminal.kill",
    "when": "terminalFocus"
  },
  {
    "key": "c c",
    "command": "workbench.debug.panel.action.clearReplAction",
    "when": "inDebugRepl"
  },
  {
    "key": "cmd+n",
    "command": "workbench.action.terminal.new",
    "when": "terminalFocus && terminalProcessSupported || terminalWebExtensionContributedProfile"
  },
  {
    "key": "alt+n",
    "command": "workbench.action.terminal.focusNext",
    "when": "terminalFocus"
  },
  // Editor movement
  {
    "key": "ctrl+tab",
    "command": "workbench.action.nextEditorInGroup"
  },
  {
    "key": "ctrl+shift+tab",
    "command": "workbench.action.previousEditorInGroup"
  },
  {
    "key": "cmd+8",
    "command": "workbench.output.action.clearOutput"
  },
  {
    "key": "alt+c",
    "command": "notebook.clearAllCellsOutputs"
  },
  {
    "key": "cmd+alt+/",
    "command": "search.action.collapseSearchResults"
  },
  {
    "command": "runCommands",
    "key": "cmd+alt+\\",
    "args": {
      "commands": [
        "search.action.collapseSearchResults",
        "workbench.files.action.collapseExplorerFolders"
      ]
    }
  },
  {
    "key": "cmd+g",
    "command": "workbench.scm.focus"
  },
  {
    "key": "cmd+shift+'",
    "command": "workbench.action.toggleMaximizedPanel"
  },
  {
    "key": "cmd+alt+l",
    "command": "editor.action.formatDocument",
    "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
  },
  // Actions
  {
    "key": "cmd+alt+x",
    "command": "workbench.action.debug.start"
  },
  {
    "key": "cmd+alt+x",
    "command": "workbench.action.debug.stop",
    "when": "debugState == 'running'"
  },
  {
    "key": "cmd+alt+c",
    "command": "workbench.action.debug.continue",
    "when": "debugState == 'stopped'"
  },
  {
    "key": "cmd+alt+;",
    "command": "workbench.action.debug.restart"
  },
  {
    "key": "cmd+alt+r",
    "command": "flutter.hotRestart"
  },
  {
    "key": "cmd+alt+h",
    "command": "flutter.hotReload"
  },
  {
    "key": "cmd+shift+r",
    "command": "flutter.hotRestart"
  },

  {
    "key": "cmd+alt+p",
    "command": "runCommands",
    "args": {
      "commands": ["workbench.action.debug.restart", "workbench.panel.repl.view.focus"]
    }
  },
  {
    "key": "cmd+shift+f5",
    "command": "-workbench.action.debug.restart",
    "when": "inDebugMode"
  },
  {
    "key": "cmd+shift+f5",
    "command": "-workbench.action.debug.restart",
    "when": "inDebugMode"
  },

  {
    "key": "f5",
    "command": "-workbench.action.debug.start",
    "when": "debuggersAvailable && debugState == 'inactive'"
  },
  {
    "key": "shift+f5",
    "command": "-workbench.action.debug.stop",
    "when": "inDebugMode && !focusedSessionIsAttach"
  },

  {
    "key": "cmd+shift+o",
    "command": "workbench.action.debug.stepOver",
    "when": "debugState == 'stopped'"
  },
  {
    "key": "f10",
    "command": "-workbench.action.debug.stepOver",
    "when": "debugState == 'stopped'"
  },

  {
    "key": "ctrl+alt+p",
    "command": "workbench.view.extension.sidebar-panel"
  },
  {
    "key": "ctrl+alt+i",
    "command": "workbench.view.extension.gitlensInspect"
  },
  {
    "key": "ctrl+.",
    "command": "workbench.action.terminal.show"
  },
  {
    "key": "shift+alt+p",
    "command": "workbench.view.extension.sidebar-panel"
  },
  {
    "key": "shift+alt+i",
    "command": "workbench.view.extension.sidebar-panel"
  },
  {
    "key": "shift+alt+i",
    "command": "workbench.view.extension.gitlensInspect"
  },
  {
    "key": "shift+alt+b",
    "command": "gitlens.showBranchesView"
  },
  {
    "key": "shift+alt+d",
    "command": "workbench.debug.action.focusBreakpointsView"
  },
  {
    "key": "alt+cmd+e",
    "command": "actions.findWithSelection"
  },
  {
    "key": "cmd+e",
    "command": "-actions.findWithSelection"
  },
  {
    "key": "ctrl+alt+b",
    "command": "workbench.action.positionPanelBottom"
  },
  {
    "key": "ctrl+alt+r",
    "command": "workbench.action.positionPanelRight"
  },
  {
    "key": "alt+cmd+t",
    "command": "todo-tree-view.focus"
  },
  {
    "key": "ctrl+alt+.",
    "command": "workbench.action.terminal.focusNextPane",
    "when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
  },
  {
    "key": "cmd+k cmd+\\",
    "command": "-workbench.action.splitEditorDown"
  },

  {
    "key": "ctrl+alt+.",
    "command": "workbench.action.terminal.focusNextPane",
    "when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
  },
  {
    "key": "cmd+up",
    "command": "cursorTop",
    "when": "editorTextFocus"
  },
  {
    "key": "cmd+down",
    "command": "cursorBottom",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+alt+enter",
    "command": "editor.action.revealDefinition",
    "when": "editorHasDefinitionProvider && editorTextFocus && !isInEmbeddedEditor"
  },
  {
    "key": "f12",
    "command": "-editor.action.revealDefinition",
    "when": "editorHasDefinitionProvider && editorTextFocus && !isInEmbeddedEditor"
  },
  {
    "key": "ctrl+e",
    "command": "editor.action.showHover",
    "when": "editorTextFocus"
  },
  {
    "key": "alt+\\",
    "command": "workbench.panel.repl.view.focus"
  },

  {
    "key": "cmd+shift+d",
    "command": "workbench.action.terminal.copyLastCommandOutput",
    "when": "terminalHasBeenCreated || terminalProcessSupported"
  },
  {
    "key": "cmd+b",
    "command": "workbench.action.toggleSidebarVisibility"
  },
  {
    "key": "cmd+b",
    "command": "-workbench.action.toggleSidebarVisibility"
  },
  {
    "key": "alt+g",
    "command": "lsp-ai.generation"
  },
  {
    "command": "editor.action.clipboardCopyWithSyntaxHighlightingAction",
    "key": "cmd+shift+c"
  },
  {
    "key": "alt+cmd+i",
    "command": "gitlens.views.searchAndCompare.focus"
  },
  {
    "key": "shift+cmd+/",
    "command": "diffEditor.switchSide",
    "when": "isInDiffEditor"
  },
  {
    "key": "cmd+shift+b",
    "command": "-workbench.action.tasks.build",
    "when": "taskCommandsRegistered"
  },
  {
    "key": "cmd+shift+b",
    "command": "workbench.panel.chat.view.copilot.focus"
  },
  {
    "key": "shift+cmd+;",
    "command": "cloudcode.gemini.chatView.focus",
    "when": "!inputFocus && !runningOnCloudShell"
  },
  {
    "key": "alt+g",
    "command": "-cloudcode.gemini.chatView.focus",
    "when": "!inputFocus && !runningOnCloudShell"
  }
]
